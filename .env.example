APP_NAME=Hapag
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
# Hapag uses MySQL. Make sure you have a database created before migrating.
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=hapag
DB_USERNAME=root
DB_PASSWORD=

# Path to mysqldump binary — required for the DB backup feature (Admin panel).
# Adjust this to match your local MySQL installation.
# Windows (Laragon example):
# MYSQLDUMP_PATH=C:/laragon/bin/mysql/mysql-8.4.3-winx64/bin/mysqldump.exe
# Linux/macOS (usually just):
# MYSQLDUMP_PATH=mysqldump
MYSQLDUMP_PATH=

# ── Session / Queue / Cache ───────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
# CACHE_PREFIX=

# ── Redis (optional — not required for local dev) ─────────────────────────────
MEMCACHED_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail (log driver is fine for local dev) ───────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@hapag.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── AWS (not used — leave blank) ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Vite ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"

# ── API Keys ──────────────────────────────────────────────────────────────────

# GROQ — used for AI food recommendations and menu item description generation.
# Get your key at: https://console.groq.com
GROQ_API_KEY=

# OpenWeatherMap — used for weather-based food suggestions on the customer dashboard.
# Get your key at: https://openweathermap.org/api
OWM_API_KEY=

# Default city for weather fallback (when user has no municipality set).
# DEFAULT_CITY=Santa Cruz,Laguna,PH

# ── Laravel Reverb (WebSockets) ───────────────────────────────────────────────
# Used for real-time order notifications (owner dashboard + customer orders).
# Run `php artisan reverb:start` to start the WebSocket server.
# Generate your own credentials — do NOT share these publicly.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Used for "Sign in with Google" on the auth modals.
# Set up credentials at: https://console.cloud.google.com
# Add your APP_URL + /auth/google/callback as an authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback
